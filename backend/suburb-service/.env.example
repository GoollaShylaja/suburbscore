# ─────────────────────────────────────────────
# suburb-service environment variables
# Copy this file to .env and fill in real values
# Database: suburbscore_suburbs (port 5433 locally)
# ─────────────────────────────────────────────

# PostgreSQL credentials
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT — must be IDENTICAL to the secret in user-service .env
# Suburb-service only validates tokens; it does not issue them
# Example: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_minimum_32_characters_long

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Swagger UI — set true during development only, false in production
SWAGGER_ENABLED=false

# Transport NSW Open Data API key
# Register free at: https://opendata.transport.nsw.gov.au/
TRANSPORT_NSW_API_KEY=your_transport_nsw_api_key

# Path to data folder containing CSV/Excel files (optional, defaults to ./data)
# DATA_DIR=./data

# Kafka broker (optional — Kafka events are skipped if not set)
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
